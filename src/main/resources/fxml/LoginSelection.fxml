<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane prefHeight="500.0" prefWidth="800.0" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LoginSelectionController">
   <children>
      <VBox alignment="CENTER" spacing="40.0" style="-fx-background-color: #1a0033;">
         <children>
            <Label style="-fx-font-size: 36; -fx-text-fill: #ffdb4d; -fx-font-weight: bold;" text="PORTAIL DE CONNEXION WARZONE" />
            
            <HBox alignment="CENTER" spacing="50.0">
               <children>
                  <!-- Carte Étudiant -->
                  <VBox alignment="CENTER" spacing="20.0" styleClass="card" prefWidth="300.0" style="-fx-border-color: #4dff4d; -fx-border-width: 2; -fx-border-radius: 15;">
                     <children>
                        <Label style="-fx-font-size: 20; -fx-text-fill: #4dff4d; -fx-font-weight: bold;" text="ACCÈS ÉTUDIANT" />
                        <Label text="Entrez sur le champ de bataille" style="-fx-text-fill: white; -fx-font-size: 12;" />
                        <Button onAction="#handleStudentAccess" prefWidth="200.0" styleClass="btn-add" text="REJOINDRE" />
                     </children>
                  </VBox>
                  
                  <!-- Carte Admin -->
                  <VBox alignment="CENTER" spacing="20.0" styleClass="card" prefWidth="300.0" style="-fx-border-color: #ff4d4d; -fx-border-width: 2; -fx-border-radius: 15;">
                     <children>
                        <Label style="-fx-font-size: 20; -fx-text-fill: #ff4d4d; -fx-font-weight: bold;" text="ADMINISTRATION" />
                        <Label text="Gérez les missions et les joueurs" style="-fx-text-fill: white; -fx-font-size: 12;" />
                        <Button onAction="#handleAdminAccess" prefWidth="200.0" styleClass="btn-delete" text="CONFIGURER" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <Label text="Système de Formation Militaire Java - V2.0" style="-fx-text-fill: #808080; -fx-font-size: 10;" />
         </children>
      </VBox>
   </children>
</StackPane>
