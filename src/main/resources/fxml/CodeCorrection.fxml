<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="700.0" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.CodeCorrectionController">
   <top>
      <VBox alignment="CENTER" style="-fx-background-color: #2e004d; -fx-padding: 20;">
         <children>
            <Label styleClass="title" text="CORRECTION DE CODE IA" />
            <Label text="L'IA a écrit un code faux. Corrigez-le !" />
         </children>
      </VBox>
   </top>
   <center>
      <VBox spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Code erroné :" />
            <TextArea fx:id="txtCode" prefHeight="200.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 14;" text="public class Main {&#10;    public static void main(String[] args) {&#10;        System.out.println(&quot;Hello&quot;)&#10;    }&#10;}" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleVerify" styleClass="btn-add" text="VÉRIFIER LA CORRECTION" />
            <Label fx:id="lblResult" textAlignment="CENTER" />
         </children>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
